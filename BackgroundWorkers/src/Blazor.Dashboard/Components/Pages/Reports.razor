@page "/reports"
@rendermode InteractiveServer
@inject ReportService ReportService
@inject JobService JobService
@implements IDisposable

@using System.ComponentModel.DataAnnotations
@using RequestProcessor

<PageTitle>Reports</PageTitle>

<!-- ── Page header ──────────────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Reports</h2>
    <div class="d-flex align-items-center gap-3">
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" role="switch" id="autoRefreshSwitch"
                   checked="@_autoRefresh" @onchange="ToggleAutoRefresh" />
            <label class="form-check-label text-muted small" for="autoRefreshSwitch">
                Auto-refresh
            </label>
        </div>
        <button class="btn btn-sm btn-outline-danger" @onclick="RemoveAll"
                disabled="@(!_reports.Any(CanRemove))" title="Remove all completed entries">
            🗑 Remove All
        </button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="ManualRefreshAsync"
                disabled="@_refreshing" title="Refresh report statuses">
            @if (_refreshing)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            }
            else
            {
                <span>↺ Refresh</span>
            }
        </button>
    </div>
</div>

<!-- ── Run Reports / Pool Stats tabs──────────────────────────────────── -->
<div class="card shadow-sm mb-4">
    <div class="card-header p-0">
        <ul class="nav nav-tabs card-header-tabs px-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == Tab.Run ? "active" : "")"
                        @onclick='() => _activeTab = Tab.Run' type="button" role="tab">
                    Run Reports
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == Tab.Stats ? "active" : "")"
                        @onclick='() => _activeTab = Tab.Stats' type="button" role="tab">
                    Pool Stats
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body">

        @if (_activeTab == Tab.Run)
        {
            <!-- ── Run Reports form ──────────────────────────────────────────── -->
            <EditForm Model="_batchForm" OnValidSubmit="CreateBatchAsync" FormName="run-reports">
                <DataAnnotationsValidator />
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">
                            Count
                            <span class="text-muted fw-normal small">— number of reports to run (1–20)</span>
                        </label>
                        <InputNumber class="form-control" @bind-Value="_batchForm.Count" min="1" max="20" />
                        <ValidationMessage For="() => _batchForm.Count" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100" disabled="@_creating">
                            @if (_creating)
                            {
                                <span class="spinner-border spinner-border-sm me-1"
                                      role="status" aria-hidden="true"></span>
                                <span>Starting…</span>
                            }
                            else
                            {
                                <span>Run</span>
                            }
                        </button>
                    </div>
                </div>
                @if (_batchSuccess is not null)
                {
                    <div class="alert alert-success mt-3 mb-0 py-2 small">@_batchSuccess</div>
                }
                @if (_createError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0 py-2 small">@_createError</div>
                }
            </EditForm>
        }
        else
        {
            <!-- ── Pool Stats ──────────────────────────────────────────────────── -->
            @if (_statsError is not null)
            {
                <div class="alert alert-danger py-2 small mb-0">
                    Could not load pool stats: @_statsError
                </div>
            }
            else if (_stats is null)
            {
                <div class="text-muted small">Loading…</div>
            }
            else
            {
                var s = _stats;
                <div class="row g-3">

                    <!-- Workers -->
                    <div class="col-12">
                        <div class="fw-semibold text-muted small text-uppercase mb-2" style="letter-spacing:.05em">Workers</div>
                        <div class="row g-2">
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-info">@s.SiloCount</div>
                                        <div class="text-muted small">Silos</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-primary">@s.ActiveWorkers</div>
                                        <div class="text-muted small">Active</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.MaxConcurrency</div>
                                        <div class="text-muted small">Max Concurrency</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.BoundedCapacity</div>
                                        <div class="text-muted small">Capacity / Priority</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Queue depth -->
                    <div class="col-12">
                        <div class="fw-semibold text-muted small text-uppercase mb-2" style="letter-spacing:.05em">Queue Depth</div>
                        <div class="row g-2">
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-danger">@s.QueueDepthHigh</div>
                                        <div class="text-muted small">High</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-warning">@s.QueueDepthNormal</div>
                                        <div class="text-muted small">Normal</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-secondary">@s.QueueDepthLow</div>
                                        <div class="text-muted small">Low</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.TotalQueueDepth</div>
                                        <div class="text-muted small">Total</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Cumulative counts -->
                    <div class="col-12">
                        <div class="fw-semibold text-muted small text-uppercase mb-2" style="letter-spacing:.05em">Cumulative</div>
                        <div class="row g-2">
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.TotalEnqueued</div>
                                        <div class="text-muted small">Enqueued</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-success">@s.TotalCompleted</div>
                                        <div class="text-muted small">Completed</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-danger">@s.TotalFailed</div>
                                        <div class="text-muted small">Failed</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-warning">@s.TotalCancelled</div>
                                        <div class="text-muted small">Cancelled</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>

<!-- ── Reports table ─────────────────────────────────────────────────────── -->
<div class="card shadow-sm">
    <div class="card-header fw-semibold d-flex align-items-center gap-2">
        <span>Reports</span>
        <span class="badge bg-secondary rounded-pill">@_reports.Count</span>
        @if (_reports.Count > 0)
        {
            <button class="btn btn-sm btn-outline-danger ms-auto"
                    @onclick="CancelAllPendingAsync"
                    disabled="@_cancellingAll"
                    title="Cancel all queued (not yet dispatched) report operations">
                @if (_cancellingAll)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>Cancelling…</span>
                }
                else
                {
                    <span>Cancel All Pending</span>
                }
            </button>
        }
    </div>
    <div class="card-body p-0">
        @if (_reports.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <div class="fs-1 mb-2">📊</div>
                <div>No reports yet — use the Run tab to start some.</div>
                <div class="small mt-1 text-muted">Each report runs three operations: Generate → Review → Publish.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:20%">Report ID</th>
                            <th style="width:8%">Started</th>
                            <th style="width:22%">
                                <span class="badge bg-secondary rounded-pill me-1">1</span>Generate
                            </th>
                            <th style="width:22%">
                                <span class="badge bg-secondary rounded-pill me-1">2</span>Review
                            </th>
                            <th style="width:22%">
                                <span class="badge bg-secondary rounded-pill me-1">3</span>Publish
                            </th>
                            <th style="width:6%" class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _reports)
                        {
                            <tr>
                                <td class="font-monospace" style="font-size:0.85rem">@r.Id</td>
                                <td class="text-muted" style="font-size:0.82rem">
                                    @r.CreatedAt.LocalDateTime.ToString("HH:mm:ss")
                                </td>

                                <!-- Generate -->
                                <td>
                                    @RenderOpCell(r.GenerateStatus, r.GenerateProgress)
                                </td>

                                <!-- Review -->
                                <td>
                                    @RenderOpCell(r.ReviewStatus, r.ReviewProgress)
                                </td>

                                <!-- Publish -->
                                <td>
                                    @RenderOpCell(r.PublishStatus, r.PublishProgress)
                                </td>

                                <!-- Actions -->
                                <td class="text-end pe-3">
                                    <div class="d-flex gap-1 justify-content-end">
                                        @if (ReportService.IsRestartable(r))
                                        {
                                            <button class="btn btn-sm btn-outline-primary"
                                                    disabled="@_busyReports.Contains(r.Id)"
                                                    @onclick="() => RestartAsync(r.Id)"
                                                    title="Restart report from Generate">
                                                Restart
                                            </button>
                                        }
                                        @if (CanRemove(r))
                                        {
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => Remove(r.Id)">
                                                Remove
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    // ── Tab enum ──────────────────────────────────────────────────────────────

    private enum Tab { Run, Stats }

    // ── Form model ────────────────────────────────────────────────────────────

    private sealed class BatchForm
    {
        [Range(1, 20, ErrorMessage = "Count must be between 1 and 20.")]
        public int Count { get; set; } = 3;
    }

    // ── State ─────────────────────────────────────────────────────────────────

    private Tab     _activeTab   = Tab.Run;
    private BatchForm _batchForm = new();
    private IReadOnlyList<ReportService.ReportEntry> _reports = [];
    private bool    _creating;
    private bool    _refreshing;
    private bool    _cancellingAll;
    private bool    _autoRefresh = true;
    private string? _createError;
    private string? _batchSuccess;
    private Timer?  _refreshTimer;
    private RequestPoolStatsSnapshot? _stats;
    private string? _statsError;

    private readonly HashSet<string> _busyReports = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _refreshTimer = new Timer(OnTimerTick, null,
            TimeSpan.FromMilliseconds(500), TimeSpan.FromMilliseconds(500));
        await RefreshAsync();
    }

    private void OnTimerTick(object? _)
    {
        if (!_autoRefresh) return;
        InvokeAsync(async () =>
        {
            await RefreshAsync();
            StateHasChanged();
        });
    }

    // ── Actions ───────────────────────────────────────────────────────────────

    private async Task ManualRefreshAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        if (_refreshing) return;
        _refreshing = true;
        try
        {
            await ReportService.RefreshAllAsync();
            _reports = ReportService.Reports;
            _batchSuccess = null;

            var snap = await JobService.GetPoolStatsAsync();
            if (snap is not null)
            {
                _stats      = snap;
                _statsError = null;
            }
        }
        catch (Exception ex)
        {
            _statsError = ex.Message;
        }
        finally { _refreshing = false; }
    }

    private async Task CreateBatchAsync()
    {
        _creating    = true;
        _createError = null;
        _batchSuccess = null;
        try
        {
            var ids = await ReportService.CreateBatchAsync(_batchForm.Count);
            _reports = ReportService.Reports;
            _batchSuccess = $"Started {ids.Count} report{(ids.Count == 1 ? "" : "s")}.";
        }
        catch (Exception ex)
        {
            _createError = $"Failed to start reports: {ex.Message}";
        }
        finally { _creating = false; }
    }

    private async Task RestartAsync(string id)
    {
        if (!_busyReports.Add(id)) return;
        _createError = null;
        try
        {
            await ReportService.RunAllAsync(id);
            _reports = ReportService.Reports;
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _busyReports.Remove(id); }
    }

    private void Remove(string id)
    {
        ReportService.Remove(id);
        _reports = ReportService.Reports;
    }

    private void RemoveAll()
    {
        ReportService.RemoveAll();
        _reports = ReportService.Reports;
    }

    private async Task CancelAllPendingAsync()
    {
        _cancellingAll = true;
        try
        {
            await ReportService.CancelAllPendingAsync();
            _reports = ReportService.Reports;
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _cancellingAll = false; }
    }

    private void ToggleAutoRefresh(ChangeEventArgs e) => _autoRefresh = e.Value is true;

    // ── Render helpers ────────────────────────────────────────────────────────

    private static bool CanRemove(ReportService.ReportEntry r) =>
        r.GenerateStatus is not (JobStatus.Processing or JobStatus.Pending) &&
        r.ReviewStatus is not (JobStatus.Processing or JobStatus.Pending) &&
        r.PublishStatus is not (JobStatus.Processing or JobStatus.Pending);

    private RenderFragment RenderOpCell(
        JobStatus status, JobProgressSnapshot? progress) =>
        @<div class="d-flex flex-column gap-1">
            <span class="badge @StatusBadgeClass(status)" style="font-size:0.75rem">
                @status
            </span>
            @if (status == JobStatus.Processing && progress is not null)
            {
                var pct = progress.PercentComplete;
                <div class="progress" style="height:4px" title="@pct%">
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         style="width:@(pct)%"
                         aria-valuenow="@pct"
                         aria-valuemin="0"
                         aria-valuemax="100">
                    </div>
                </div>
                @if (progress.Message is not null)
                {
                    <div class="text-muted" style="font-size:0.7rem; line-height:1.2">@progress.Message</div>
                }
            }
            else if (status == JobStatus.Completed && progress is not null)
            {
                var pct = progress.PercentComplete;
                <div class="progress" style="height:4px" title="@pct%">
                    <div class="progress-bar bg-success"
                         role="progressbar"
                         style="width:@(pct)%"
                         aria-valuenow="@pct"
                         aria-valuemin="0"
                         aria-valuemax="100">
                    </div>
                </div>
            }
            else if (status is JobStatus.Failed or JobStatus.Cancelled && progress is not null)
            {
                var pct = progress.PercentComplete;
                <div class="progress" style="height:4px" title="@pct%">
                    <div class="progress-bar @(status == JobStatus.Failed ? "bg-danger" : "bg-warning")"
                         role="progressbar"
                         style="width:@(pct)%"
                         aria-valuenow="@pct"
                         aria-valuemin="0"
                         aria-valuemax="100">
                    </div>
                </div>
            }
        </div>;

    private static string StatusBadgeClass(JobStatus status) => status switch
    {
        JobStatus.Unknown => "bg-secondary",
        JobStatus.Pending => "bg-info",
        JobStatus.Processing => "bg-primary",
        JobStatus.Completed => "bg-success",
        JobStatus.Failed => "bg-danger",
        JobStatus.Cancelled => "bg-warning",
        _ => "bg-secondary"
    };

    void IDisposable.Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
