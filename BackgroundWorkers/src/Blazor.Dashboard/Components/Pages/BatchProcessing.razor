@page "/batch-processing"
@rendermode InteractiveServer
@inject BatchService BatchService
@inject JobService JobService
@implements IDisposable

@using System.ComponentModel.DataAnnotations
@using RequestProcessor

<PageTitle>Batch Processing</PageTitle>

<!-- ── Page header ──────────────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Batch Processing</h2>
    <div class="d-flex align-items-center gap-3">
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" role="switch" id="autoRefreshSwitch"
                   checked="@_autoRefresh" @onchange="ToggleAutoRefresh" />
            <label class="form-check-label text-muted small" for="autoRefreshSwitch">
                Auto-refresh
            </label>
        </div>
        <button class="btn btn-sm btn-outline-danger" @onclick="RemoveAll"
                disabled="@(!_batches.Any(CanRemove))" title="Remove all completed entries">
            🗑 Remove All
        </button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="ManualRefreshAsync"
                disabled="@_refreshing" title="Refresh batch statuses">
            @if (_refreshing)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            }
            else
            {
                <span>↺ Refresh</span>
            }
        </button>
    </div>
</div>

<!-- ── Run Batches / Pool Stats tabs──────────────────────────────────── -->
<div class="card shadow-sm mb-4">
    <div class="card-header p-0">
        <ul class="nav nav-tabs card-header-tabs px-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == Tab.Run ? "active" : "")"
                        @onclick='() => _activeTab = Tab.Run' type="button" role="tab">
                    Run Batches
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == Tab.Stats ? "active" : "")"
                        @onclick='() => _activeTab = Tab.Stats' type="button" role="tab">
                    Pool Stats
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body">

        @if (_activeTab == Tab.Run)
        {
            <!-- ── Run Batches form ──────────────────────────────────────────── -->
            <EditForm Model="_batchForm" OnValidSubmit="CreateBatchAsync" FormName="run-batches">
                <DataAnnotationsValidator />
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">
                            Item Count
                            <span class="text-muted fw-normal small">— items per batch (1–1000)</span>
                        </label>
                        <InputNumber class="form-control" @bind-Value="_batchForm.ItemCount" min="1" max="1000" />
                        <ValidationMessage For="() => _batchForm.ItemCount" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">
                            Worker Count
                            <span class="text-muted fw-normal small">— workers (1–20)</span>
                        </label>
                        <InputNumber class="form-control" @bind-Value="_batchForm.WorkerCount" min="1" max="20" />
                        <ValidationMessage For="() => _batchForm.WorkerCount" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100" disabled="@_creating">
                            @if (_creating)
                            {
                                <span class="spinner-border spinner-border-sm me-1"
                                      role="status" aria-hidden="true"></span>
                                <span>Starting…</span>
                            }
                            else
                            {
                                <span>Run</span>
                            }
                        </button>
                    </div>
                </div>
                @if (_batchSuccess is not null)
                {
                    <div class="alert alert-success mt-3 mb-0 py-2 small">@_batchSuccess</div>
                }
                @if (_createError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0 py-2 small">@_createError</div>
                }
            </EditForm>
        }
        else
        {
            <!-- ── Pool Stats ──────────────────────────────────────────────────── -->
            @if (_statsError is not null)
            {
                <div class="alert alert-danger py-2 small mb-0">
                    Could not load pool stats: @_statsError
                </div>
            }
            else if (_stats is null)
            {
                <div class="text-muted small">Loading…</div>
            }
            else
            {
                var s = _stats;
                <div class="row g-3">

                    <!-- Workers -->
                    <div class="col-12">
                        <div class="fw-semibold text-muted small text-uppercase mb-2" style="letter-spacing:.05em">Workers</div>
                        <div class="row g-2">
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-info">@s.SiloCount</div>
                                        <div class="text-muted small">Silos</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-primary">@s.ActiveWorkers</div>
                                        <div class="text-muted small">Active</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.MaxConcurrency</div>
                                        <div class="text-muted small">Max Concurrency</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.BoundedCapacity</div>
                                        <div class="text-muted small">Capacity / Priority</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Queue depth -->
                    <div class="col-12">
                        <div class="fw-semibold text-muted small text-uppercase mb-2" style="letter-spacing:.05em">Queue Depth</div>
                        <div class="row g-2">
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-danger">@s.QueueDepthHigh</div>
                                        <div class="text-muted small">High</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-warning">@s.QueueDepthNormal</div>
                                        <div class="text-muted small">Normal</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-secondary">@s.QueueDepthLow</div>
                                        <div class="text-muted small">Low</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.TotalQueueDepth</div>
                                        <div class="text-muted small">Total</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Cumulative counts -->
                    <div class="col-12">
                        <div class="fw-semibold text-muted small text-uppercase mb-2" style="letter-spacing:.05em">Cumulative</div>
                        <div class="row g-2">
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold">@s.TotalEnqueued</div>
                                        <div class="text-muted small">Enqueued</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-success">@s.TotalCompleted</div>
                                        <div class="text-muted small">Completed</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-danger">@s.TotalFailed</div>
                                        <div class="text-muted small">Failed</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="card text-center border-0 bg-light h-100">
                                    <div class="card-body py-2 px-1">
                                        <div class="fs-4 fw-bold text-warning">@s.TotalCancelled</div>
                                        <div class="text-muted small">Cancelled</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>

<!-- ── Batches table ───────────────────────────────────────────────────── -->
<div class="card shadow-sm">
    <div class="card-header fw-semibold d-flex align-items-center gap-2">
        <span>Batches</span>
        <span class="badge bg-secondary rounded-pill">@_batches.Count</span>
        @if (_batches.Count > 0)
        {
            <button class="btn btn-sm btn-outline-danger ms-auto"
                    @onclick="CancelAllPendingAsync"
                    disabled="@_cancellingAll"
                    title="Cancel all queued (not yet dispatched) batches">
                @if (_cancellingAll)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>Cancelling…</span>
                }
                else
                {
                    <span>Cancel All Pending</span>
                }
            </button>
        }
    </div>
    <div class="card-body p-0">
        @if (_batches.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <div class="fs-1 mb-2">📦</div>
                <div>No batches yet — use the Run tab to start some.</div>
                <div class="small mt-1 text-muted">Each batch distributes work across multiple worker grains.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:18%">Batch ID</th>
                            <th style="width:10%">Started</th>
                            <th style="width:8%">Items</th>
                            <th style="width:8%">Workers</th>
                            <th style="width:12%">Status</th>
                            <th style="width:29%">Progress</th>
                            <th style="width:15%" class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _batches)
                        {
                            var s = b.Summary;
                            var done = s is null ? 0 : s.TotalCompleted + s.TotalFailed + s.TotalCancelled;
                            var total = b.ItemCount > 0 ? b.ItemCount : 1;
                            var pct = s is null ? 0 : (int)Math.Round(done * 100.0 / total);
                            <tr>
                                <td class="font-monospace" style="font-size:0.85rem">@b.Id</td>
                                <td class="text-muted" style="font-size:0.82rem">
                                    @b.CreatedAt.LocalDateTime.ToString("HH:mm:ss")
                                </td>
                                <td>@b.ItemCount</td>
                                <td>@b.WorkerCount</td>
                                <td>
                                    <span class="badge @StatusBadgeClass(b.Status)" style="font-size:0.75rem">
                                        @b.Status
                                    </span>
                                </td>
                                <td>
                                    @if (s is not null)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:6px">
                                                <div class="progress-bar @ProgressBarClass(b.Status)"
                                                     role="progressbar"
                                                     style="width:@(pct)%"
                                                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                                </div>
                                            </div>
                                            <small class="text-muted text-nowrap" style="font-size:0.75rem">
                                                @s.TotalCompleted/@b.ItemCount
                                                @if (s.TotalFailed > 0)
                                                {
                                                    <span class="text-danger ms-1">@s.TotalFailed ✕</span>
                                                }
                                                @if (s.TotalCancelled > 0)
                                                {
                                                    <span class="text-warning ms-1">@s.TotalCancelled ⊘</span>
                                                }
                                            </small>
                                        </div>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex gap-1 justify-content-end">
                                        @if (BatchService.IsRestartable(b))
                                        {
                                            <button class="btn btn-sm btn-outline-primary"
                                                    disabled="@_busyBatches.Contains(b.Id)"
                                                    @onclick="() => RestartAsync(b.Id)"
                                                    title="Restart batch with same configuration">
                                                Restart
                                            </button>
                                        }
                                        @if (CanRemove(b))
                                        {
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => Remove(b.Id)">
                                                Remove
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    // ── Tab enum ──────────────────────────────────────────────────────────────

    private enum Tab { Run, Stats }

    // ── Form model ────────────────────────────────────────────────────────────

    private sealed class BatchForm
    {
        [Range(1, 1000, ErrorMessage = "Item Count must be between 1 and 1000.")]
        public int ItemCount { get; set; } = 100;

        [Range(1, 20, ErrorMessage = "Worker Count must be between 1 and 20.")]
        public int WorkerCount { get; set; } = 5;
    }

    // ── State ─────────────────────────────────────────────────────────────────

    private Tab _activeTab = Tab.Run;
    private BatchForm _batchForm = new();
    private IReadOnlyList<BatchService.BatchEntry> _batches = [];
    private bool _creating;
    private bool _refreshing;
    private bool _cancellingAll;
    private bool _autoRefresh = true;
    private string? _createError;
    private string? _batchSuccess;
    private Timer? _refreshTimer;
    private RequestPoolStatsSnapshot? _stats;
    private string? _statsError;

    private readonly HashSet<string> _busyBatches = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _refreshTimer = new Timer(OnTimerTick, null,
            TimeSpan.FromMilliseconds(500), TimeSpan.FromMilliseconds(500));
        await RefreshAsync();
    }

    private void OnTimerTick(object? _)
    {
        if (!_autoRefresh) return;
        InvokeAsync(async () =>
        {
            await RefreshAsync();
            StateHasChanged();
        });
    }

    // ── Actions ───────────────────────────────────────────────────────────────

    private async Task ManualRefreshAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        if (_refreshing) return;
        _refreshing = true;
        try
        {
            await BatchService.RefreshAllAsync();
            _batches = BatchService.Batches;
            _batchSuccess = null;

            var snap = await JobService.GetPoolStatsAsync();
            if (snap is not null)
            {
                _stats = snap;
                _statsError = null;
            }
        }
        catch (Exception ex)
        {
            _statsError = ex.Message;
        }
        finally { _refreshing = false; }
    }

    private async Task CreateBatchAsync()
    {
        _creating = true;
        _createError = null;
        _batchSuccess = null;
        try
        {
            var id = await BatchService.CreateBatchAsync(_batchForm.ItemCount, _batchForm.WorkerCount);
            _batches = BatchService.Batches;
            _batchSuccess = $"Started batch {id}.";
        }
        catch (Exception ex)
        {
            _createError = $"Failed to start batch: {ex.Message}";
        }
        finally { _creating = false; }
    }

    private async Task RestartAsync(string id)
    {
        if (!_busyBatches.Add(id)) return;
        _createError = null;
        try
        {
            var batch = _batches.FirstOrDefault(b => b.Id == id);
            if (batch is not null)
            {
                await BatchService.CreateBatchAsync(batch.ItemCount, batch.WorkerCount);
                _batches = BatchService.Batches;
            }
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _busyBatches.Remove(id); }
    }

    private void Remove(string id)
    {
        BatchService.Remove(id);
        _batches = BatchService.Batches;
    }

    private void RemoveAll()
    {
        BatchService.RemoveAll();
        _batches = BatchService.Batches;
    }

    private async Task CancelAllPendingAsync()
    {
        _cancellingAll = true;
        try
        {
            await BatchService.CancelAllPendingAsync();
            _batches = BatchService.Batches;
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _cancellingAll = false; }
    }

    private void ToggleAutoRefresh(ChangeEventArgs e) => _autoRefresh = e.Value is true;

    // ── Render helpers ────────────────────────────────────────────────────────

    private static bool CanRemove(BatchService.BatchEntry b) =>
        b.Status is not (JobStatus.Processing or JobStatus.Pending);

    private static string StatusBadgeClass(JobStatus status) => status switch
    {
        JobStatus.Unknown => "bg-secondary",
        JobStatus.Pending => "bg-info",
        JobStatus.Processing => "bg-primary",
        JobStatus.Completed => "bg-success",
        JobStatus.Failed => "bg-danger",
        JobStatus.Cancelled => "bg-warning text-dark",
        _ => "bg-light text-dark border"
    };

    private static string ProgressBarClass(JobStatus status) => status switch
    {
        JobStatus.Failed    => "bg-danger",
        JobStatus.Cancelled => "bg-warning",
        JobStatus.Completed => "bg-success",
        _                   => "bg-primary progress-bar-striped progress-bar-animated"
    };

    public void Dispose() => _refreshTimer?.Dispose();
}
